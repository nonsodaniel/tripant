# Tripant Environment Variables
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Tripant

# Overpass API (OpenStreetMap POI data - free, no key needed)
NEXT_PUBLIC_OVERPASS_API=https://overpass-api.de/api/interpreter

# Nominatim geocoding (free, no key needed)
NEXT_PUBLIC_NOMINATIM_API=https://nominatim.openstreetmap.org

# Open-Meteo weather (free, no key needed)
NEXT_PUBLIC_WEATHER_API=https://api.open-meteo.com/v1
